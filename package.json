{
  "name": "stonecutter",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader native",
    "build": "vite build --configLoader native",
    "lint": "eslint .",
    "test": "node src/lib/run-tests.js",
    "preview": "vite preview --configLoader native",
    "tauri": "tauri",
    "installer:win": "tauri build --target x86_64-pc-windows-msvc",
    "release:precheck": "powershell -ExecutionPolicy Bypass -File .\\scripts\\release-precheck.ps1",
    "release:bump": "powershell -ExecutionPolicy Bypass -File .\\scripts\\bump-version.ps1",
    "release:patch": "powershell -ExecutionPolicy Bypass -File .\\scripts\\bump-version.ps1 -Increment patch",
    "release:minor": "powershell -ExecutionPolicy Bypass -File .\\scripts\\bump-version.ps1 -Increment minor",
    "release:major": "powershell -ExecutionPolicy Bypass -File .\\scripts\\bump-version.ps1 -Increment major",
    "release:commit": "powershell -ExecutionPolicy Bypass -File .\\scripts\\release-commit.ps1",
    "release:tag": "powershell -ExecutionPolicy Bypass -File .\\scripts\\release-tag.ps1",
    "release:push-tags": "powershell -ExecutionPolicy Bypass -File .\\scripts\\release-push-tags.ps1",
    "release:all": "powershell -ExecutionPolicy Bypass -File .\\scripts\\release-all.ps1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.10"
  }
}
