{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "StoneCutter",
  "version": "0.1.1",
  "identifier": "com.stonecutter.editor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "StoneCutter",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "shortDescription": "Nonlinear video editor for source trimming, timeline editing, and MP4 export.",
    "longDescription": "StoneCutter is a Tauri 2 + React 19 desktop video editor prototype with source-preview In/Out ranges, timeline drag/drop, snapping, trimming, multi-selection, image clips, audio-only clips, playback, and FFmpeg-based MP4 export.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "startMenuFolder": "StoneCutter",
        "installerIcon": "icons/icon.ico"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
